# =============================================================================
# DevOps Lab - .gitignore
# =============================================================================

# Terraform / OpenTofu
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
crash.log
*.tfvars
!terraform.tfvars.example

# Kubernetes
kubeconfig
*.kubeconfig

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Node.js (Frontends)
node_modules/
dist/
.cache/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Go (Backends/Workers)
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
vendor/

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
*.egg-info/
.eggs/
*.egg
.env
.venv/
venv/

# Rust
target/
Cargo.lock

# Docker
*.tar

# Secrets (never commit!)
*.pem
*.key
secrets/
.env.local
.env.*.local
